{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "version": "0.1.0",
  "default_locale": "ru",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "mask-prompt": {
      "suggested_key": { "default": "Alt+Shift+M" },
      "description": "__MSG_cmd_mask__"
    },
    "restore-selection": {
      "suggested_key": { "default": "Alt+Shift+U" },
      "description": "__MSG_cmd_restore__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
